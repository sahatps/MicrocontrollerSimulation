
.hackCable-root
  height 100%
  width 100%
  display flex
  flex-direction column
  flex-wrap nowrap
  position relative

  p, h1, h2, h3, h4, select
    font-family Rubik
    color #c9c9c9

  h3
    font-weight 400
    font-size .9em
    text-align center
    word-wrap break-word

  .hackCable-header
    height 44px
    width 100%
    background-color #30343F
    border-bottom 1px solid black
    display flex
    align-items center
    padding 0 10px
    gap 8px
    flex-shrink 0
    position relative
    z-index 200

  .hackCable-toggle-catalog
    border none
    border-radius 5px
    padding 6px 12px
    cursor pointer
    transition background-color 0.2s
    font-size 13px
    background-color #424B5A
    color #c9c9c9
    height 32px
    display flex
    align-items center
    gap 6px
    flex-shrink 0

    &:hover
      background-color #4e5768

    &.active
      background-color #5a6478
      color white

    .toggle-icon
      font-size 16px
      line-height 1

    .toggle-label
      font-family Rubik
      font-size 13px

  .hackCable-catalog-bar
    width 100%
    background-color #383d4a
    border-bottom 1px solid #222
    flex-shrink 0
    overflow hidden
    max-height 140px
    transition max-height 0.3s ease

    &.hidden
      max-height 0
      border-bottom none

    .hackCable-catalog-bar-inner
      display flex
      flex-direction row
      align-items stretch
      height 140px
      padding 6px 8px
      gap 8px
      box-sizing border-box

    .hackCable-catalog-actions
      display flex
      align-items center
      flex-shrink 0
      padding-right 8px
      border-right 1px solid #555

      select
        padding 4px 6px
        background-color #f5f5f5
        border-radius 3px
        border none
        color black
        font-size 12px
        cursor pointer
        width 120px

        option
          color black
          background-color white

    .hackCable-catalog-list
      display flex
      flex-direction row
      align-items center
      gap 8px
      overflow-x auto
      overflow-y hidden
      flex 1
      scrollbar-width thin
      padding-bottom 4px

      .hackCable-catalog-section
        display flex
        flex-direction row
        align-items center
        gap 8px
        flex-shrink 0

        .hackCable-catalog-section-header
          background #30343F
          padding 6px 10px
          cursor pointer
          border-radius 5px
          display flex
          align-items center
          gap 6px
          user-select none
          transition background 0.2s ease
          height 100px
          writing-mode vertical-rl
          text-orientation mixed
          flex-shrink 0

          &:hover
            background #3a444f

          .hackCable-section-toggle-icon
            font-size 0.75em
            font-weight bold

          span
            font-weight 500
            color #c9c9c9
            font-size 0.8em

        .hackCable-catalog-section-content
          display flex
          flex-direction row
          gap 8px

      .hackCable-catalog-element
        display flex
        flex-direction column
        align-items center
        justify-content center
        border-radius 5px
        background #30343F
        padding 6px 8px
        cursor pointer
        transition background 0.2s ease
        flex-shrink 0
        width 80px
        height 110px
        overflow hidden

        &:hover
          background #3a444f

        h3
          margin 4px 0 0 0
          font-size 0.7em
          white-space nowrap
          overflow hidden
          text-overflow ellipsis
          width 100%
          text-align center

  .hackCable-content-wrapper
    display flex
    flex-direction row
    flex 1
    overflow hidden

  .hackCable-editor
    background-color white
    width 100%
    flex 1
    overflow auto
    scrollbar-width thin
    position relative

    #hackCable-canvas
      width 100%
      min-width 800px
      height 100%
      min-height 600px
      position relative

      .hackCable-canvas-overlay-container
        height 100%
        width 100%
        position absolute
        overflow hidden
        transform-origin left top

        background-color rgba(0, 0, 0, 0)
        background-position 0 0, 0 0
        background-repeat repeat, repeat
        background-attachment scroll, scroll
        background-image linear-gradient(to right, rgb(240, 240, 240) 1px, transparent 1px), linear-gradient(rgb(240, 240, 240) 1px, rgb(255, 255, 255) 1px)
        background-clip border-box, border-box
        background-size 20px 20px

        *
          position absolute
          transform-origin left top

    // Canvas Toolbar styles
    .hackCable-canvas-toolbar
      position sticky
      bottom 10px
      left 50%
      transform translateX(-50%)
      z-index 1000
      display flex
      flex-direction row
      gap 5px
      width fit-content
      opacity 0
      pointer-events none
      transition opacity 0.2s ease

      &.visible
        opacity 1
        pointer-events auto

      .hackCable-toolbar-bin
        width 40px
        height 40px
        background-color rgba(200, 200, 200, 0.8)
        border-radius 8px
        display flex
        align-items center
        justify-content center
        cursor pointer
        transition all 0.2s ease

        svg
          color #666
          transition color 0.2s ease

        &.active
          opacity 1
          pointer-events auto
          background-color rgba(255, 100, 100, 0.3)
          border 2px dashed #ff6666

        &.hover
          background-color rgba(255, 50, 50, 0.6)
          border 2px solid #ff0000
          transform scale(1.1)

          svg
            color #fff

      .hackCable-toolbar-btn
        width 36px
        height 36px
        background-color rgba(255, 255, 255, 0.9)
        border 1px solid #ccc
        border-radius 6px
        display flex
        align-items center
        justify-content center
        cursor pointer
        transition all 0.2s ease

        svg
          color #424B5A

        &:hover:not(:disabled)
          background-color #e0e0e0
          border-color #999

        &:disabled
          opacity 0.4
          cursor not-allowed

        &:active:not(:disabled)
          transform scale(0.95)

// Responsive canvas styles for tablets
@media screen and (max-width: 1024px)
  .hackCable-root
    .hackCable-editor
      #hackCable-canvas
        min-width 600px
        min-height 500px

// Responsive canvas styles for mobile devices
@media screen and (max-width: 768px)
  .hackCable-root
    .hackCable-catalog-bar
      max-height 120px

      .hackCable-catalog-bar-inner
        height 120px

      .hackCable-catalog-list
        .hackCable-catalog-element
          width 70px
          height 90px

    .hackCable-editor
      height 60vh
      min-height 300px

      #hackCable-canvas
        min-width 500px
        min-height 400px

// Responsive canvas styles for small mobile devices
@media screen and (max-width: 480px)
  .hackCable-root
    .hackCable-catalog-bar
      max-height 110px

      .hackCable-catalog-bar-inner
        height 110px

    .hackCable-editor
      height 65vh

      #hackCable-canvas
        min-width 400px
        min-height 300px



